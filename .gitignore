# Unity 프로젝트용 .gitignore
# 그래픽 에셋 (스프라이트, 텍스처 등)은 포함됩니다

# Unity가 자동 생성하는 폴더들
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# Unity 자동 생성 파일
*.log
*.stackdump
sysinfo.txt

# 메모리 캡처 및 녹화 파일
[Mm]emoryCaptures/
[Rr]ecordings/

# Blender 백업 파일
*.blend1
*.blend1.meta

# Visual Studio 관련
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# Rider 관련
.idea/
[Aa]ssets/Plugins/Editor/JetBrains*
*.DotSettings.user

# Gradle 캐시
.gradle/

# VS 자동 생성 프로젝트 파일
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.tmp
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D 생성 메타 파일
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Mono 자동 생성 파일
mono_crash.*

# 빌드 결과물
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics
crashlytics-build.properties

# TestRunner 생성 파일
InitTestScene*.unity*

# Addressables
[Ss]erverData/
[Aa]ssets/StreamingAssets/aa*
[Aa]ssets/AddressableAssetsData/link.xml*
[Aa]ssets/Addressables_Temp*
[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting 자동 생성
[Aa]ssets/Unity.VisualScripting.Generated/

# Play Mode 테스트 자동 생성 씬
[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# OS 생성 파일
.DS_Store
Thumbs.db
Desktop.ini

# ===================================
# Resources 폴더의 이미지/텍스처 파일 제외
# ===================================
[Aa]ssets/[Rr]esources/**/*.png
[Aa]ssets/[Rr]esources/**/*.jpg
[Aa]ssets/[Rr]esources/**/*.jpeg
[Aa]ssets/[Rr]esources/**/*.psd
[Aa]ssets/[Rr]esources/**/*.tga
[Aa]ssets/[Rr]esources/**/*.bmp
[Aa]ssets/[Rr]esources/**/*.gif
[Aa]ssets/[Rr]esources/**/*.tif
[Aa]ssets/[Rr]esources/**/*.tiff
[Aa]ssets/[Rr]esources/**/*.exr
[Aa]ssets/[Rr]esources/**/*.hdr

# Resources 폴더의 애니메이션 및 머티리얼 파일 제외
[Aa]ssets/[Rr]esources/**/*.anim
[Aa]ssets/[Rr]esources/**/*.mat
[Aa]ssets/[Rr]esources/**/*.controller
[Aa]ssets/[Rr]esources/**/*.prefab

# Resources 폴더의 메타 파일도 제외
[Aa]ssets/[Rr]esources/**/*.meta
